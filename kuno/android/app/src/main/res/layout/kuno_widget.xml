<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF7F2"
    android:padding="8dp">

    <!-- Spine Color Strip (Main Book) -->
    <ImageView
        android:id="@+id/widget_spine_strip"
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:background="#6B8F71"
        android:contentDescription="Spine" />

    <LinearLayout
        android:id="@+id/widget_main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toEndOf="@id/widget_spine_strip"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kuno"
            android:textColor="#C17F4A"
            android:textSize="9sp"
            android:textStyle="bold" />

        <!-- Main Book Section -->
        <LinearLayout
            android:id="@+id/widget_book_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <TextView
                android:id="@+id/widget_book_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="No book reading"
                android:textColor="#2C2416"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_book_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Add a book"
                android:textColor="#8B7355"
                android:textSize="10sp" />

            <ProgressBar
                android:id="@+id/widget_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/widget_progress_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0% complete"
                android:textColor="#8B7355"
                android:textSize="8sp" />
        </LinearLayout>

        <!-- Divider -->
        <ImageView
            android:id="@+id/widget_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0D5C5"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:contentDescription="Divider"
            android:visibility="gone" />

        <!-- Other Books List (Up to 3 more) -->
        <LinearLayout
            android:id="@+id/widget_other_books"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Book 2 -->
            <LinearLayout
                android:id="@+id/widget_book_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp"
                android:visibility="gone">
                <ImageView android:id="@+id/widget_spine_2" android:layout_width="3dp" android:layout_height="12dp" android:background="#C17F4A" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/widget_book_title_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:textColor="#2C2416" android:textSize="10sp" android:textStyle="bold" />
                <TextView android:id="@+id/widget_progress_text_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:textColor="#C17F4A" android:textSize="9sp" android:textStyle="bold" />
            </LinearLayout>

            <!-- Book 3 -->
            <LinearLayout
                android:id="@+id/widget_book_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp"
                android:visibility="gone">
                <ImageView android:id="@+id/widget_spine_3" android:layout_width="3dp" android:layout_height="12dp" android:background="#C17F4A" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/widget_book_title_3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:textColor="#2C2416" android:textSize="10sp" android:textStyle="bold" />
                <TextView android:id="@+id/widget_progress_text_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:textColor="#C17F4A" android:textSize="9sp" android:textStyle="bold" />
            </LinearLayout>

            <!-- Book 4 -->
            <LinearLayout
                android:id="@+id/widget_book_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">
                <ImageView android:id="@+id/widget_spine_4" android:layout_width="3dp" android:layout_height="12dp" android:background="#C17F4A" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/widget_book_title_4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:textColor="#2C2416" android:textSize="10sp" android:textStyle="bold" />
                <TextView android:id="@+id/widget_progress_text_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:textColor="#C17F4A" android:textSize="9sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
