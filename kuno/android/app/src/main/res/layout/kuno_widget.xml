<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF7F2"
    android:padding="8dp">

    <!-- Spine Color Strip -->
    <View
        android:id="@+id/widget_spine_strip"
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:background="#C17F4A" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/widget_spine_strip"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kuno"
            android:textColor="#C17F4A"
            android:textSize="12sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/widget_book_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="No book currently reading"
            android:textColor="#2C2416"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_book_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Add a book to start"
            android:textColor="#8B7355"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/widget_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress_bar" />

        <TextView
            android:id="@+id/widget_progress_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="end"
            android:text="0% complete"
            android:textColor="#8B7355"
            android:textSize="10sp" />

    </LinearLayout>

</RelativeLayout>
