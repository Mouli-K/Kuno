<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF7F2"
    android:padding="8dp">

    <!-- Spine Color Strip (Main Book) -->
    <ImageView
        android:id="@+id/widget_spine_strip"
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:background="#6B8F71"
        android:contentDescription="Spine" />

    <LinearLayout
        android:id="@+id/widget_main_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/widget_spine_strip"
        android:layout_marginStart="12dp"
        android:orientation="vertical"
        android:layout_centerVertical="true">

        <TextView
            android:id="@+id/widget_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kuno"
            android:textColor="#C17F4A"
            android:textSize="10sp" />

        <!-- Main Book Section -->
        <LinearLayout
            android:id="@+id/widget_book_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <TextView
                android:id="@+id/widget_book_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="No book reading"
                android:textColor="#2C2416"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_book_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Add a book"
                android:textColor="#8B7355"
                android:textSize="11sp" />

            <ProgressBar
                android:id="@+id/widget_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/widget_progress_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0% complete"
                android:textColor="#8B7355"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Secondary Book Section (Optional) -->
        <LinearLayout
            android:id="@+id/widget_book_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical"
            android:visibility="gone">
            
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0D5C5"
                android:layout_marginBottom="4dp"
                android:contentDescription="Divider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <ImageView
                    android:id="@+id/widget_spine_2"
                    android:layout_width="4dp"
                    android:layout_height="16dp"
                    android:background="#C17F4A"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="Spine" />

                <TextView
                    android:id="@+id/widget_book_title_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Second Book"
                    android:textColor="#2C2416"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                
                <TextView
                    android:id="@+id/widget_progress_text_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="50%"
                    android:textColor="#C17F4A"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
